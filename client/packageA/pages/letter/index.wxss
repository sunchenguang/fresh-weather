/* 主题色彩 */
page {
  font-family: 'PingFang SC', 'Microsoft YaHei', '微软雅黑', Arial, sans-serif;
  color: #2c3e50;
  background: linear-gradient(135deg, #fef7f7 0%, #fff9fc 100%);
}

.page {
  width: 100%;
  min-height: 100vh;
  position: relative;
}

/* 返回按钮 */
.back-button {
  position: fixed;
  left: 30rpx;
  z-index: 1001;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease, opacity 0.3s ease;
  pointer-events: auto;
}

.back-button.show {
  opacity: 1;
  transform: translateX(0);
}

.back-button.hide {
  opacity: 0;
  transform: translateX(-100rpx);
  pointer-events: none;
}

.back-button:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.back-icon {
  font-size: 36rpx;
  color: #2c3e50;
  font-weight: bold;
}

.back-text {
  font-size: 28rpx;
  color: #2c3e50;
}

/* 音乐播放器 */
.music-player {
  position: fixed;
  bottom: 60rpx;
  right: 60rpx;
  z-index: 1000;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  padding: 24rpx 40rpx;
  border-radius: 100rpx;
  box-shadow: 0 8rpx 40rpx rgba(255, 107, 157, 0.2);
}

.play-btn {
  width: 90rpx;
  height: 90rpx;
  border: none;
  background: #ff6b9d;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.play-btn::after {
  border: none;
}

.play-icon,
.pause-icon {
  font-size: 40rpx;
  color: white;
}

.music-info {
  display: flex;
  flex-direction: column;
}

.music-title {
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: 500;
}

/* 滚动视图 */
.scroll-view {
  height: 100vh;
  position: relative;
  z-index: 1;
}

/* 封面页 */
.hero-section {
  position: relative;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: linear-gradient(135deg, rgba(255, 182, 193, 0.1) 0%, rgba(255, 192, 203, 0.05) 100%);
}

.hero-content {
  max-width: 1600rpx;
  padding: 40rpx;
}

.hero-title {
  font-size: 90rpx;
  font-weight: 300;
  color: #ff6b9d;
  margin-bottom: 40rpx;
  letter-spacing: 0.1em;
  font-family: 'STKaiti', 'KaiTi', '楷体', serif;
}

.hero-subtitle {
  font-size: 40rpx;
  color: #c44569;
  margin-bottom: 120rpx;
  font-weight: 300;
  opacity: 0;
  animation: fadeInUp 1s ease 1.5s forwards;
}

.scroll-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  color: #ff6b9d;
  font-size: 28rpx;
  opacity: 0;
  animation: fadeInUp 1s ease 2s forwards, bounce 2s ease-in-out 3s infinite;
  padding: 20rpx;
  transition: transform 0.3s ease, opacity 0.3s ease;
}

.scroll-indicator:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.arrow {
  font-size: 48rpx;
}

/* 信件容器 */
.letter-container {
  position: relative;
  max-width: 1600rpx;
  margin: 0 auto;
  padding: 160rpx 80rpx;
}

.letter-section {
  margin-bottom: 120rpx;
  opacity: 0;
  transform: translateY(60rpx);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.letter-section.visible {
  opacity: 1;
  transform: translateY(0);
}

.letter-date {
  font-size: 32rpx;
  color: #c44569;
  margin-bottom: 60rpx;
  text-align: right;
  font-weight: 300;
  letter-spacing: 0.1em;
}

.letter-text {
  font-size: 36rpx;
  line-height: 2;
  color: #2c3e50;
  margin-bottom: 60rpx;
  text-align: justify;
  font-weight: 300;
  letter-spacing: 0.05em;
  display: block;
}

.letter-signature {
  font-size: 48rpx;
  color: #ff6b9d;
  text-align: right;
  margin-top: 120rpx;
  font-family: 'STKaiti', 'KaiTi', '楷体', serif;
  font-weight: 400;
}

.signature-date {
  font-size: 32rpx;
  color: #c44569;
  display: block;
  margin-top: 20rpx;
}

/* 爱心动画容器 */
.hearts-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 999;
}

.heart {
  position: absolute;
  font-size: 40rpx;
  color: #ff6b9d;
  pointer-events: none;
  animation: floatUp 3s ease-out forwards;
  opacity: 0.8;
}

/* 动画定义 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

@keyframes floatUp {
  0% {
    opacity: 0.8;
    transform: translateY(0) scale(0.5) rotate(0deg);
  }
  50% {
    opacity: 1;
    transform: translateY(-200rpx) scale(1) rotate(10deg);
  }
  100% {
    opacity: 0;
    transform: translateY(-400rpx) scale(0.8) rotate(-10deg);
  }
}

@keyframes typing {
  from {
    width: 0;
  }
  to {
    width: 100%;
  }
}

/* 打字机效果 */
.typing-effect {
  overflow: hidden;
  white-space: nowrap;
  border-right: 6rpx solid #ff6b9d;
  animation: typing 2s steps(8, end), blink 0.75s step-end infinite;
}

@keyframes blink {
  from, to {
    border-color: transparent;
  }
  50% {
    border-color: #ff6b9d;
  }
}

/* 延迟淡入 */
.fade-in-delay {
  opacity: 0;
  animation: fadeInUp 1s ease 1.5s forwards;
}

.fade-in-delay-2 {
  opacity: 0;
  animation: fadeInUp 1s ease 2s forwards;
}
