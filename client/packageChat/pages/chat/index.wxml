<view class="page">
  <view class="nav" style="padding-top: {{statusBarPx}}px;">
    <view class="nav-inner">
      <view class="nav-back" bindtap="onBack">‹</view>
      <text class="nav-title">AI 助手</text>
      <view class="nav-right" />
    </view>
  </view>

  <scroll-view
    class="thread"
    scroll-y
    scroll-with-animation
    scroll-into-view="{{scrollIntoView}}"
    style="height: {{scrollHeightPx}}px;"
  >
    <view class="thread-pad">
      <block wx:for="{{messages}}" wx:key="id">
        <view id="anchor-{{item.id}}" class="msg-row {{item.role === 'user' ? 'msg-row--me' : 'msg-row--peer'}}">
          <block wx:if="{{item.role !== 'user'}}">
            <view class="avatar avatar--ai"><text>A</text></view>
            <view class="msg-main">
              <view class="bubble bubble--ai">
                <text wx:if="{{item.toolStatus}}" class="tool-hint">{{item.toolStatus}}</text>
                <block wx:if="{{item.parts && item.parts.length}}">
                  <block wx:for="{{item.parts}}" wx:for-item="part" wx:key="key">
                    <view wx:if="{{part.type === 'text'}}" class="part part--text">
                      <rich-text
                        wx:if="{{part.richNodes && part.richNodes.length}}"
                        class="bubble-rich"
                        nodes="{{part.richNodes}}"
                      />
                      <text wx:else class="bubble-text" selectable>{{part.text}}</text>
                    </view>
                    <view wx:elif="{{part.type === 'reasoning'}}" class="part part--reasoning">
                      <text class="reasoning-label">推理过程</text>
                      <rich-text
                        wx:if="{{part.richNodes && part.richNodes.length}}"
                        class="reasoning-rich"
                        nodes="{{part.richNodes}}"
                      />
                      <text wx:else class="reasoning-text" selectable>{{part.text}}</text>
                    </view>
                    <view wx:elif="{{part.type === 'tool'}}" class="tool-card">
                      <view class="tool-card__head">
                        <text class="tool-card__label">{{part.toolLabel}}</text>
                        <text
                          wx:if="{{part.phase === 'input_streaming'}}"
                          class="tool-card__phase tool-card__phase--pending"
                        >准备参数…</text>
                        <text
                          wx:elif="{{part.phase === 'running'}}"
                          class="tool-card__phase tool-card__phase--pending"
                        >执行中…</text>
                        <text wx:elif="{{part.phase === 'done'}}" class="tool-card__phase">已完成</text>
                        <text wx:elif="{{part.phase === 'error'}}" class="tool-card__phase tool-card__phase--err">失败</text>
                      </view>
                      <view wx:if="{{part.inputPreview}}" class="tool-card__input">
                        <text class="tool-card__mono" selectable>{{part.inputPreview}}</text>
                      </view>
                      <view wx:if="{{part.phase === 'error' && part.errorText}}" class="tool-card__err">
                        <text class="tool-card__mono" selectable>{{part.errorText}}</text>
                      </view>
                      <block wx:elif="{{part.webItems && part.webItems.length}}">
                        <view class="tool-card__results">
                          <block wx:for="{{part.webItems}}" wx:for-item="hit" wx:for-index="hidx" wx:key="hidx">
                            <view class="tool-hit">
                              <text wx:if="{{hit.ref}}" class="tool-hit__ref">引用 {{hit.ref}}</text>
                              <text wx:if="{{hit.title}}" class="tool-hit__title">{{hit.title}}</text>
                              <text
                                wx:if="{{hit.url}}"
                                class="tool-hit__url"
                                selectable
                                data-url="{{hit.url}}"
                                bindtap="onCopyUrl"
                              >{{hit.url}}</text>
                              <text wx:if="{{hit.summary}}" class="tool-hit__summary">{{hit.summary}}</text>
                            </view>
                          </block>
                        </view>
                      </block>
                      <view wx:elif="{{part.outputText}}" class="tool-card__out">
                        <text class="tool-card__mono" selectable>{{part.outputText}}</text>
                      </view>
                    </view>
                  </block>
                </block>
                <block wx:else>
                  <text class="bubble-text" selectable>{{item.text}}</text>
                </block>
              </view>
            </view>
          </block>
          <block wx:else>
            <view class="msg-main">
              <view class="bubble bubble--me">
                <block wx:if="{{item.parts && item.parts.length}}">
                  <block wx:for="{{item.parts}}" wx:for-item="part" wx:key="key">
                    <view wx:if="{{part.type === 'text'}}" class="part part--text">
                      <text class="bubble-text" selectable>{{part.text}}</text>
                    </view>
                  </block>
                </block>
                <block wx:else>
                  <text class="bubble-text" selectable>{{item.text}}</text>
                </block>
              </view>
            </view>
            <view class="avatar avatar--me"><text>我</text></view>
          </block>
        </view>
      </block>
      <view class="bottom-spacer" />
    </view>
  </scroll-view>

  <view class="composer safe-bottom" style="padding-bottom: {{safeBottomPx}}px;">
    <view class="composer-row">
      <input
        class="composer-input"
        value="{{inputValue}}"
        bindinput="onInput"
        confirm-type="send"
        bindconfirm="onSend"
        placeholder="发消息…"
        adjust-position="{{true}}"
        disabled="{{streaming}}"
      />
      <button
        class="send-btn"
        bindtap="onSend"
        disabled="{{streaming || !canSend}}"
        hover-class="send-btn--hover"
      >
        发送
      </button>
    </view>
  </view>
</view>
