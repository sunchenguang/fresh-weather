.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #ededed;
  box-sizing: border-box;
}

.nav {
  flex-shrink: 0;
  background: #ededed;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
}

.nav-inner {
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 12rpx;
}

.nav-back {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 52rpx;
  color: #181818;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #181818;
}

.nav-right {
  width: 88rpx;
  height: 88rpx;
}

.thread {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}

.thread-pad {
  padding: 18rpx 0 24rpx;
}

.msg-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 0 20rpx;
  margin-bottom: 28rpx;
}

.msg-row--me {
  flex-direction: row;
  justify-content: flex-end;
}

.msg-row--peer {
  flex-direction: row;
  justify-content: flex-start;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  background: #d9d9d9;
}

.avatar--me {
  background: #c8e3ff;
  color: #174d82;
}

.avatar--ai {
  background: #e6e6e6;
  color: #333;
}

.msg-main {
  max-width: 490rpx;
  margin: 0 18rpx;
}

.bubble {
  border-radius: 8rpx;
  padding: 18rpx 22rpx;
  line-height: 1.55;
  word-wrap: break-word;
  position: relative;
}

.bubble--ai {
  background: #ffffff;
  color: #111;
  box-shadow: 0 1rpx 0 rgba(0, 0, 0, 0.04);
}

.bubble--me {
  background: #95ec69;
  color: #111;
}

.bubble-text {
  font-size: 32rpx;
  white-space: pre-wrap;
}

.tool-hint {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.bottom-spacer {
  height: 24rpx;
}

.composer {
  flex-shrink: 0;
  background: #f7f7f7;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
  padding: 16rpx 20rpx 16rpx;
}

.composer-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.composer-input {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.send-btn {
  margin-left: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  background: #07c160;
  color: #ffffff;
  border-radius: 12rpx;
  border: none;
}

.send-btn::after {
  border: none;
}

.send-btn[disabled] {
  opacity: 0.45;
  background: #07c160;
  color: #ffffff;
}

.send-btn--hover {
  opacity: 0.9;
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
}
