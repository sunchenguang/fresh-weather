.page {
  min-height: 100vh;
  background: radial-gradient(ellipse at 50% 35%, #2a2045 0%, #0a0a14 55%);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.ambient {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.ring {
  position: absolute;
  left: 50%;
  top: 42%;
  width: 580rpx;
  height: 580rpx;
  margin-left: -290rpx;
  margin-top: -290rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(232, 197, 71, 0.25);
  box-shadow: 0 0 120rpx rgba(232, 197, 71, 0.08);
}

.ring.pulse {
  animation: ringPulse 3.2s ease-in-out infinite;
}

@keyframes ringPulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.85;
  }
  50% {
    transform: scale(1.06);
    opacity: 1;
  }
}

.spark {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  margin: -5rpx 0 0 -5rpx;
  border-radius: 50%;
  background: #ffe9a8;
  box-shadow: 0 0 16rpx #e8c547;
  opacity: 0;
  animation: burst 1s ease-out forwards;
}

@keyframes burst {
  0% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(0.35);
  }
  100% {
    opacity: 0;
    transform: translate3d(0, -280rpx, 0) scale(0.12);
  }
}

.content {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 620rpx;
}

.q {
  display: block;
  font-size: 44rpx;
  line-height: 1.55;
  color: #fdf8ff;
  margin-bottom: 100rpx;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.yes {
  width: 400rpx;
  height: 104rpx;
  line-height: 104rpx;
  border-radius: 52rpx;
  background: linear-gradient(135deg, #d4af37 0%, #f5e6a8 50%, #e8c547 100%);
  color: #1f1828;
  font-size: 36rpx;
  letter-spacing: 0.28em;
  border: none;
  box-shadow: 0 20rpx 60rpx rgba(212, 175, 55, 0.45);
}

.yes::after {
  border: none;
}

.yes[disabled] {
  opacity: 0.65;
}

.overlay {
  position: fixed;
  inset: 0;
  background: rgba(6, 4, 12, 0.72);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.45s ease;
  padding: 48rpx;
  box-sizing: border-box;
}

.overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.sheet {
  width: 100%;
  max-width: 600rpx;
  background: linear-gradient(160deg, rgba(40, 32, 64, 0.96) 0%, rgba(22, 18, 38, 0.98) 100%);
  border-radius: 28rpx;
  padding: 72rpx 48rpx 56rpx;
  text-align: center;
  position: relative;
  border: 1rpx solid rgba(232, 197, 71, 0.28);
  box-shadow: 0 32rpx 100rpx rgba(0, 0, 0, 0.55);
  animation: sheetIn 0.55s cubic-bezier(0.34, 1.4, 0.64, 1);
}

@keyframes sheetIn {
  from {
    opacity: 0;
    transform: scale(0.88) translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.sheet-glow {
  position: absolute;
  top: -40rpx;
  left: 50%;
  width: 200rpx;
  height: 200rpx;
  margin-left: -100rpx;
  background: radial-gradient(circle, rgba(232, 197, 71, 0.35) 0%, transparent 70%);
  pointer-events: none;
}

.sheet-title {
  display: block;
  font-size: 48rpx;
  color: #ffeaa3;
  margin-bottom: 28rpx;
  letter-spacing: 0.12em;
}

.sheet-sub {
  display: block;
  font-size: 36rpx;
  color: rgba(240, 235, 255, 0.9);
  margin-bottom: 36rpx;
  letter-spacing: 0.08em;
}

.sheet-hint {
  font-size: 24rpx;
  color: rgba(200, 195, 220, 0.55);
}
