.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #101022 0%, #1a1530 100%);
  padding: 100rpx 40rpx 80rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.halo {
  position: absolute;
  width: 700rpx;
  height: 500rpx;
  top: -80rpx;
  left: 50%;
  transform: translateX(-50%);
  background: radial-gradient(ellipse, rgba(232, 197, 71, 0.12) 0%, transparent 70%);
  pointer-events: none;
}

.card {
  position: relative;
  z-index: 2;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 28rpx;
  padding: 56rpx 40rpx 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.35);
}

.q {
  display: block;
  font-size: 34rpx;
  line-height: 1.55;
  color: #f2f0ff;
  margin-bottom: 48rpx;
  font-weight: 400;
}

.opts {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.opt {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  background: rgba(30, 28, 50, 0.9);
  color: #e8e4fc;
  font-size: 30rpx;
  border: 1rpx solid rgba(232, 197, 71, 0.22);
  text-align: center;
  padding: 0;
}

.opt::after {
  border: none;
}

.opt:active {
  background: rgba(232, 197, 71, 0.18);
}
