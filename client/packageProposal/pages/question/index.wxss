/* 与 open 同源：星夜渐变 + 星光；整体提亮，并以色温与辅助光晕区分答题页 */

.page {
  min-height: 100vh;
  /* open 为 165° 深靛蓝；此处略浅、角度稍偏，偏「暮色将尽」 */
  background: linear-gradient(152deg, #18182e 0%, #303058 36%, #2d4a78 100%);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.page::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 55%;
  background: radial-gradient(ellipse 130% 70% at 50% 100%, rgba(245, 198, 120, 0.07) 0%, transparent 62%);
  pointer-events: none;
  z-index: 0;
}

.starfield {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.star {
  position: absolute;
  box-sizing: border-box;
  border-radius: 50%;
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite;
  will-change: opacity, transform;
}

.star--tone-warm {
  background: rgba(255, 238, 210, 0.95);
  box-shadow:
    0 0 10rpx rgba(255, 228, 180, 0.95),
    0 0 22rpx rgba(255, 210, 140, 0.42);
}

.star--tone-cool {
  background: rgba(230, 242, 255, 0.88);
  box-shadow:
    0 0 10rpx rgba(200, 230, 255, 0.82),
    0 0 20rpx rgba(160, 200, 255, 0.32);
}

.star--sz-sm {
  width: 4rpx;
  height: 4rpx;
}

.star--sz-lg {
  width: 7rpx;
  height: 7rpx;
}

.star--tw-a {
  animation-name: twinkle-sparkle;
}

.star--tw-b {
  animation-name: twinkle-soft;
}

.star--tw-c {
  animation-name: twinkle-swell;
}

@keyframes twinkle-sparkle {
  0%, 100% {
    opacity: 0.15;
    transform: scale(0.65);
  }
  12% {
    opacity: 1;
    transform: scale(1.35);
  }
  28% {
    opacity: 0.35;
    transform: scale(0.9);
  }
  45% {
    opacity: 0.9;
    transform: scale(1.15);
  }
  70% {
    opacity: 0.25;
    transform: scale(0.85);
  }
}

@keyframes twinkle-soft {
  0%, 100% {
    opacity: 0.35;
    transform: scale(0.85);
  }
  50% {
    opacity: 1;
    transform: scale(1.25);
  }
}

@keyframes twinkle-swell {
  0%, 100% {
    opacity: 0.2;
    transform: scale(0.75);
    filter: brightness(0.85);
  }
  40% {
    opacity: 0.85;
    transform: scale(1.08);
    filter: brightness(1.05);
  }
  65% {
    opacity: 0.55;
    transform: scale(1.2);
    filter: brightness(1.15);
  }
}

.ambient-glow {
  position: absolute;
  pointer-events: none;
  z-index: 0;
}

/* open 单束居中偏上暖光；答题页：略偏右上 + 次要薄荷偏左下，形成对话感 */
.ambient-glow--gold {
  width: 720rpx;
  height: 720rpx;
  left: 62%;
  top: 12%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(232, 197, 71, 0.2) 0%, rgba(245, 215, 160, 0.06) 42%, transparent 68%);
}

.ambient-glow--mint {
  width: 520rpx;
  height: 520rpx;
  left: -8%;
  bottom: 8%;
  transform: translateY(40%);
  background: radial-gradient(circle, rgba(125, 211, 192, 0.12) 0%, rgba(94, 200, 220, 0.04) 45%, transparent 70%);
}

.grid-fade {
  position: absolute;
  inset: 0;
  opacity: 0.055;
  background-image: linear-gradient(rgba(255, 255, 255, 0.4) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.32) 1rpx, transparent 1rpx);
  background-size: 56rpx 56rpx;
  pointer-events: none;
  z-index: 0;
}

.safe-top {
  flex-shrink: 0;
  width: 100%;
}

.masthead {
  flex-shrink: 0;
  padding: 8rpx 40rpx 20rpx;
  position: relative;
  z-index: 2;
}

.masthead-inner {
  border-left: 6rpx solid rgba(245, 198, 120, 0.55);
  padding-left: 28rpx;
}

.mast-kicker {
  display: block;
  font-size: 22rpx;
  letter-spacing: 0.42em;
  text-transform: uppercase;
  color: rgba(167, 243, 228, 0.75);
  margin-bottom: 12rpx;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

.mast-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.35;
  color: #faf6ef;
  font-weight: 500;
  letter-spacing: 0.06em;
  margin-bottom: 28rpx;
}

.progress-block {
  margin-bottom: 20rpx;
}

.progress-track {
  height: 6rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
  position: relative;
}

.progress-glow {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(245, 198, 120, 0.25), transparent);
  opacity: 0.5;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #e8b86a 0%, #f5e6c8 50%, #7dd3c0 100%);
  transition: width 0.45s cubic-bezier(0.33, 1, 0.68, 1);
  box-shadow: 0 0 24rpx rgba(245, 198, 120, 0.35);
}

.progress-caption {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(230, 225, 255, 0.45);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.12em;
}

.step-dots {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.step-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
}

.step-dot--done {
  background: rgba(245, 198, 120, 0.35);
  border-color: rgba(245, 198, 120, 0.4);
}

.step-dot--here {
  transform: scale(1.35);
  background: rgba(167, 243, 228, 0.9);
  border-color: rgba(200, 255, 244, 0.95);
  box-shadow: 0 0 20rpx rgba(125, 211, 192, 0.45);
}

/* 高度由 JS 写入 style，满足真机 scroll-view 对固定高度的要求 */
.scroll {
  position: relative;
  z-index: 2;
  padding: 0 40rpx;
  box-sizing: border-box;
}

/* 至少铺满滚动视口，便于 flex 分配留白 */
.scroll-inner {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.card-wrap {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: 16rpx;
  padding-bottom: 28rpx;
}

.card-ribbon {
  position: absolute;
  top: 0;
  right: 48rpx;
  width: 8rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: linear-gradient(180deg, rgba(245, 198, 120, 0.9), rgba(125, 211, 192, 0.5));
  opacity: 0.85;
}

.card {
  position: relative;
  background: linear-gradient(
    165deg,
    rgba(255, 255, 255, 0.09) 0%,
    rgba(18, 28, 48, 0.72) 45%,
    rgba(10, 16, 32, 0.88) 100%
  );
  border-radius: 32rpx;
  padding: 48rpx 40rpx 44rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 32rpx 100rpx rgba(0, 0, 0, 0.45), inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(20px);
}

.card-kicker {
  display: block;
  font-size: 26rpx;
  color: rgba(167, 243, 228, 0.88);
  letter-spacing: 0.2em;
  margin-bottom: 24rpx;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

.q-rule {
  width: 72rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: linear-gradient(90deg, rgba(245, 198, 120, 0.85), transparent);
  margin-bottom: 28rpx;
}

.q {
  display: block;
  font-size: 34rpx;
  line-height: 1.65;
  color: #f7f4ff;
  margin-bottom: 44rpx;
  font-weight: 400;
  letter-spacing: 0.02em;
}

.opts {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 20rpx;
  width: 100%;
}

.opt {
  display: flex;
  align-items: center;
  width: 100%;
  margin: 0;
  box-sizing: border-box;
  gap: 24rpx;
  min-height: 100rpx;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(8, 12, 24, 0.65);
  color: #ebe8ff;
  font-size: 29rpx;
  line-height: 1.45;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  text-align: left;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
}

.opt::after {
  border: none;
}

/* 避免按下时整块变成金色 + 松手后变回，看起来像「背景闪一下」；略提亮即可 */
.opt:active {
  background: rgba(10, 15, 30, 0.78);
  border-color: rgba(255, 255, 255, 0.16);
}

.opt-idx {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  line-height: 44rpx;
  text-align: center;
  color: rgba(245, 198, 120, 0.95);
  background: rgba(245, 198, 120, 0.1);
  border: 1rpx solid rgba(245, 198, 120, 0.28);
}

.opt-txt {
  flex: 1;
  min-width: 0;
  text-align: left;
}

.closing {
  flex-shrink: 0;
  margin-top: auto;
  padding: 28rpx 8rpx 8rpx;
}

.closing-line {
  width: 100%;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.12) 20%,
    rgba(255, 255, 255, 0.12) 80%,
    transparent
  );
  margin-bottom: 32rpx;
  opacity: 0.9;
}

.closing-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.75;
  color: rgba(230, 225, 255, 0.42);
  letter-spacing: 0.04em;
  margin-bottom: 20rpx;
}

.closing-hint {
  display: block;
  font-size: 22rpx;
  color: rgba(167, 243, 228, 0.45);
  letter-spacing: 0.08em;
}

.scroll-pad {
  flex-shrink: 0;
  height: calc(24rpx + env(safe-area-inset-bottom));
  min-height: 48rpx;
}

/* 答对：触点向上飘散爱心，渐隐 */
.heart-fly-layer {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 80;
  pointer-events: none;
}

.heart-fly {
  position: absolute;
  transform: translate(-50%, -50%);
  animation: heart-fly-rise 0.96s cubic-bezier(0.28, 0.72, 0.35, 1) forwards;
}

.heart-fly__shape {
  display: block;
  font-size: 44rpx;
  line-height: 1;
  color: rgba(255, 182, 193, 0.95);
  text-shadow:
    0 0 16rpx rgba(255, 192, 203, 0.65),
    0 0 36rpx rgba(245, 198, 120, 0.35);
}

@keyframes heart-fly-rise {
  0% {
    opacity: 0.96;
    transform: translate(-50%, -50%) translateY(0) scale(0.9);
  }
  18% {
    opacity: 1;
    transform: translate(-50%, -50%) translateY(-14rpx) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) translateY(-200rpx) scale(1.08);
  }
}