<view class="page">
  <view class="starfield">
    <view
      class="star star--tone-{{item.tone}} star--sz-{{item.size}} star--tw-{{item.tw}}"
      wx:for="{{stars}}"
      wx:key="id"
      style="left: {{item.x}}%; top: {{item.y}}%; animation-delay: {{item.delay}}s; animation-duration: {{item.duration}}s;"
    ></view>
  </view>
  <view class="glow"></view>
  <view class="main">
    <view class="body {{visible ? 'in' : ''}}">
      <text class="kicker">{{copy.kicker}}</text>
      <view class="title-wrap">
        <text class="title">{{copy.title}}</text>
      </view>
      <text class="hint">{{copy.hint}}</text>
    </view>
    <view class="bridge {{visible ? 'bridge-in' : ''}}">
      <view class="lunar">
        <view class="moon"></view>
        <view class="moon-halo"></view>
        <view class="orbit orbit-a"></view>
        <view class="orbit orbit-b"></view>
      </view>
      <view class="trail">
        <view
          class="trail-item"
          wx:for="{{copy.trail}}"
          wx:key="id"
          style="transition-delay: {{item.delay}}s;"
        >
          <view class="trail-node">
            <view class="trail-dot"></view>
          </view>
          <view class="trail-card">
            <text class="trail-title">{{item.title}}</text>
            <text class="trail-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
      <view class="bridge-ribbon">
        <view class="chevron"></view>
        <text class="bridge-hint">轻触下方，走进故事里</text>
      </view>
    </view>
  </view>
  <view class="footer">
    <button class="cta" bindtap="onContinue">下一刻</button>
  </view>
</view>
