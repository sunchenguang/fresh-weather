.page {
  min-height: 100vh;
  background: #090911;
  position: relative;
}

.swiper {
  width: 100%;
  height: 100vh;
}

.slide {
  width: 100%;
  height: 100%;
  position: relative;
}

.photo {
  width: 100%;
  height: 100%;
  display: block;
}

.vignette {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.15) 0%,
    transparent 30%,
    transparent 55%,
    rgba(9, 9, 17, 0.75) 100%
  );
  pointer-events: none;
}

.caption {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 48rpx);
  left: 0;
  right: 0;
  text-align: center;
  z-index: 5;
  pointer-events: none;
}

.caption text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 0.2em;
}

.footer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: calc(env(safe-area-inset-bottom) + 64rpx);
  z-index: 6;
  display: flex;
  justify-content: center;
}

.cta {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: rgba(20, 20, 40, 0.65);
  color: #e8c547;
  font-size: 30rpx;
  letter-spacing: 0.16em;
  border: 1rpx solid rgba(232, 197, 71, 0.45);
}

.cta::after {
  border: none;
}
